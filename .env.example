# Copy this file to .env and fill in whichever key(s) you want to use.
# Both are optional -- without them the pipeline uses Ollama (if running)
# or falls back to heuristic highlights + template scripts.

# Groq free tier (~14k requests/day) -- get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini free tier -- get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
